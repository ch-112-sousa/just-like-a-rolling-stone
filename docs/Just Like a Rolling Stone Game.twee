:: StoryStylesheet [stylesheet]
.title
{
   text-align: center;
   font-size: 40px;
}

.subTitle
{
   text-align: center;
   font-size: 22px;
}

.txt-center
{
    text-align: center;
}

.my-div {
  margin:0 auto;
  width:30%;
  background-color: #222;
  font-family: Consolas !important;
  font-size:16px !important;
  color: whitesmoke;
  border: 2px solid gold;
  padding: 20px;
  margin: 10px 0;
  border-radius: 8px;  	
}

html, body
{
  font-size:16px !important;
  line-height: 0.5 !important;
  margin: 0;
  padding: 0;
}

